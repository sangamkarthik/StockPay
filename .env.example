OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# Optional YOLO-compatible hosted object detector.
# Roboflow hosted API format: YOLO_MODEL_ID=project-slug/version-number
# Example endpoint used by default: https://detect.roboflow.com/:modelId?api_key=...
YOLO_MODEL_ID=
YOLO_API_KEY=
YOLO_API_URL=https://detect.roboflow.com
YOLO_CONFIDENCE=35
YOLO_OVERLAP=30

# Optional once North sends the exact embed URL or SDK flow.
VITE_NORTH_CHECKOUT_ID=
VITE_NORTH_PROFILE_ID=
VITE_NORTH_EMBED_URL=
VITE_NORTH_SCRIPT_URL=https://checkout.north.com/checkout.js
NORTH_CHECKOUT_ID=
NORTH_PROFILE_ID=
NORTH_PRIVATE_API_KEY=
NORTH_API_BASE=https://checkout-api.north.com/public
NORTH_WEBHOOK_MODE=mock
NORTH_WEBHOOK_SIGNING_SECRET=
